datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Patient {
  id          String   @id @default(uuid())
  name        String
  birthDate   DateTime?
  sex         String?
  profession  String?
  anamnese    Json?
  diagnosisHistory Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  appointments Appointment[]
  packages    PackageSession[]
  finances    Finance[]
  balance     Float?
}

model Appointment {
  id            String   @id @default(uuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  date          DateTime
  duration      Int
  status        String   @default("scheduled")
  treatmentType String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Package {
  id           String   @id @default(cuid())
  name         String
  description  String?
  totalSessions Int
  price        Float
  discount     Float?
  validityDays Int?
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     PackageSession[]
}

model PackageSession {
  id            String   @id @default(cuid())
  packageId     String
  package       Package  @relation(fields: [packageId], references: [id])
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  sessionNumber Int
  usedAt        DateTime?
  used          Boolean  @default(false)
  appointmentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Finance {
  id            String   @id @default(cuid())
  type          String
  description   String
  amount        Float
  date          DateTime
  category      String?
  paymentMethod String?
  patientId     String?
  patient       Patient? @relation(fields: [patientId], references: [id])
  appointmentId String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Synergy {
  id          String   @id @default(cuid())
  title       String
  description String
  procedure   String
  category    String
  mainPoints  String[]
  rationale   String
  precautions String
  steps       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Knowledge {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  category    String
  subcategory String?
  content     String
  summary     String?
  tags        String[]
  references  String[]
  images      String[]
  videoUrl    String?
  metadata    Json?
  isActive    Boolean   @default(true)
  viewCount   Int       @default(0)
  tagEntries  KnowledgeTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      String?
}

model KnowledgeCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  icon        String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  parentId    String?
  parent      KnowledgeCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    KnowledgeCategory[] @relation("CategoryHierarchy")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model KnowledgeTag {
  id          String    @id @default(cuid())
  name        String    @unique
  createdAt   DateTime  @default(now())
  knowledge   Knowledge[]
}
